# === Mang x402 V2 (CAIP-2) ===
# "base-sepolia" (hoac eip155:84532) = TESTNET. Facilitator free, KHONG can CDP key.
#                  => DUNG CAI NAY TRUOC de dang ky x402scan + xac nhan v2 chay.
# "base" (hoac eip155:8453)          = MAINNET. CAN CDP key. Ra tien that.
X402_NETWORK=base-sepolia

# Vi nhan USDC tren Base (dia chi EVM).
PAY_TO=0xYOUR_WALLET_ADDRESS_HERE
RECIPIENT_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE

# Gia moi call (chuoi USD kieu x402).
X402_PRICE=0.02

# Facilitator cho TESTNET (mainnet bo qua, dung @coinbase/x402 + CDP key).
FACILITATOR_URL=https://x402.org/facilitator

# CHI CAN khi X402_NETWORK=base (mainnet). Lay o portal.cdp.coinbase.com.
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# URL cong khai khi deploy (KHONG dau / cuoi).
BASE_URL=http://localhost:3000

# Email lien he (hien trong openapi).
CONTACT_EMAIL=

# RPC doc token (de trong = public). Giong rug-check EVM.
ETH_RPC_URL=
BNB_RPC_URL=
BASE_RPC_URL=

# Preview key (TEST bo qua thanh toan). XOA tren production.
PREVIEW_KEY=
