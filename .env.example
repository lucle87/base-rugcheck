# === Mang x402 ===
# "base-sepolia" = testnet (facilitator free, KHONG can CDP key) - test truoc.
# "base"         = mainnet (CAN CDP key) - ra tien that.
X402_NETWORK=base-sepolia

# Vi nhan USDC tren Base (dia chi EVM).
PAY_TO=0xYOUR_WALLET_ADDRESS_HERE
RECIPIENT_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE

# Gia moi call (chuoi USD kieu x402).
X402_PRICE=$0.02

# Facilitator cho TESTNET (mainnet bo qua, dung @coinbase/x402).
FACILITATOR_URL=https://x402.org/facilitator

# CHI CAN khi X402_NETWORK=base (mainnet). Lay o Coinbase Developer Platform.
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# URL cong khai khi deploy (KHONG dau / cuoi).
BASE_URL=http://localhost:3000

# Email lien he (hien trong openapi).
CONTACT_EMAIL=

# RPC doc token (de trong = public). Tuong tu rug-check EVM.
ETH_RPC_URL=
BNB_RPC_URL=
BASE_RPC_URL=

# Preview key (TEST bo qua thanh toan). XOA tren production.
PREVIEW_KEY=
